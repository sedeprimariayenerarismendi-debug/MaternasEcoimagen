generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  nombre    String
  email     String    @unique
  password  String
  rol       String    @default("ENFERMERA")
  activo    Boolean   @default(true)
  maternas  Materna[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Materna {
  id              Int      @id @default(autoincrement())
  nombre          String
  documento       String   @unique
  tipoDocumento   String
  fechaNacimiento DateTime
  fechaEmbarazo   DateTime
  fechaRegistro   DateTime @default(now())
  tipoRiesgo      String   // BAJA, MEDIANA, ALTA
  alertas         String?
  telefono        String?
  direccion       String?
  contactoEmergencia String?
  creadaPorId     Int
  creadaPor       User             @relation(fields: [creadaPorId], references: [id])
  eventos         EventoMedico[]
  carpetaEntregada Boolean          @default(false)
  fichaFomag      FichaFomag?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model EventoMedico {
  id              Int      @id @default(autoincrement())
  tipo            String   // CITA, ESTUDIO, CONTROL
  descripcion     String
  fechaProgramada DateTime
  fechaRealizada  DateTime?
  estado          String   @default("PENDIENTE") // PENDIENTE, REALIZADO, CANCELADO
  esObligatorio   Boolean  @default(false)
  esControl       Boolean  @default(false)
  estaAgendado      Boolean   @default(false)
  fechaAgendamiento DateTime?
  resultado         String?
  codigoCUPS      String?
  prestadores     Prestador[]
  notas           String?
  cantidad        Int?     @default(1)
  trimestre       String?
  paqueteId       Int?
  plantillaId     Int?
  plantilla       PlantillaEvento? @relation(fields: [plantillaId], references: [id], onDelete: SetNull)
  // Variables clínicas FOMAG para controles
  tensionArterial         String?  // ej: "120/80"
  peso                    Float?   // kg
  clasificacionNutricional String? // NORMAL, BP, SP, OB1, OB2
  alturaUterina           Float?   // cm
  frecuenciaCardiacaFetal Int?     // lpm
  edadGestacional         Int?     // Semanas
  riesgoObstetrico        String?
  diagnosticoAro          String?
  riesgoPsicosocial       String?
  atributoRiesgoPsicosocial String?
  imc                     Float?
  prescripcionAsa         String?
  riesgoTromboembolico    String?
  riesgoHipertension      String?
  riesgoPreeclampsia      String?
  toxoplasmaIgmControl    String?
  hemoparasitosControl    String?
  maternaId       Int
  materna         Materna  @relation(fields: [maternaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaqueteEventos {
  id              Int               @id @default(autoincrement())
  nombre          String
  descripcion     String?
  trimestre       String?
  plantillas      PlantillaEvento[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PlantillaEvento {
  id               Int            @id @default(autoincrement())
  tipo             String         // CITA, ESTUDIO, CONTROL
  descripcion      String
  semanasRelativas Int            @default(0) // Semanas desde fechaEmbarazo
  esObligatorio    Boolean        @default(false)
  esControl        Boolean        @default(false)
  codigoCUPS       String?
  cantidad         Int            @default(1)
  trimestre        String?
  paqueteId        Int
  paquete          PaqueteEventos @relation(fields: [paqueteId], references: [id], onDelete: Cascade)
  eventos          EventoMedico[]
}

model Prestador {
  id              Int            @id @default(autoincrement())
  nombre          String         @unique
  nit             String?
  eventos         EventoMedico[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ThemeConfig {
  id              Int     @id @default(autoincrement())
  primaryColor    String  @default("#E91E8C")
  secondaryColor  String  @default("#3B82F6")
  accentColor     String  @default("#F472B6")
  darkMode        Boolean @default(false)
  clinicName      String  @default("Clínica Maternas")
  logoUrl         String?
}

// ─── FOMAG Cohorte Materno Perinatal ──────────────────────────────────────

model FichaFomag {
  id                    Int       @id @default(autoincrement())
  maternaId             Int       @unique
  materna               Materna   @relation(fields: [maternaId], references: [id], onDelete: Cascade)

  // Ubicación e identificación FOMAG
  regional              String?   // 1-10
  departamento          String?
  municipio             String?
  ips                   String?
  correo                String?

  // Características sociodemográficas (enums FOMAG)
  grupoEtnico           String?   // MESTIZO, AFRO, INDIGENA, RAIZAL, ROM, NORESP
  nivelEducativo        String?   // T=Técnico, E=Escolar, U=Universitario, O=Otro
  ocupacion             String?
  regimen               String?   // CONTRIBUTIVO, SUBSIDIADO, VINCULADO, ESPECIAL
  tipoVinculacion       String?   // AFILIADO, BENEFICIARIO
  etnia                 String?
  identidadGenero       String?
  discapacidad          String?
  victimaViolencia      String?
  embarazoDeseado       String?
  redApoyo              String?
  tamizajeViolencia     String?
  tamizajeDepresion     String?

  // Preconcepcionales
  atencionPreconcepcional String?
  asesoriaAnticonceptivo  String?
  acidoFolicoPrevio       String?
  citasPreconcepcionales  Int?

  // Información gestacional adicional
  fechaUltimaRegla      DateTime?
  fechaProbableParto    DateTime?
  fechaIngresoControl   DateTime?
  antecedentes          String?

  // Micronutrientes
  hierroCantidad        String?
  hierroFecha           DateTime?
  acidoFolicoCantidad   String?
  acidoFolicoFecha      DateTime?
  calcioCantidad        String?
  calcioFecha           DateTime?

  // Laboratorios FOMAG
  hemoglobina1Fecha            DateTime?
  hemoglobina1Resultado        String?
  hemoglobina2Fecha            DateTime?
  hemoglobina2Resultado        String?
  hemoclasificacionFecha       DateTime?
  hemoclasificacionResultado   String?
  serologiaFecha               DateTime?
  serologiaResultado           String?
  vihFecha                     DateTime?
  vihResultado                 String?
  glicemiaFecha                DateTime?
  glicemiaResultado            String?
  urocultivoFecha              DateTime?
  urocultivoResultado          String?
  frotisFecha                  DateTime?
  frotisResultado              String?
  toxoplasmaIggFecha           DateTime?
  toxoplasmaIggResultado       String?
  toxoplasmaIgmFecha           DateTime?
  toxoplasmaIgmResultado       String?
  sifilis1Fecha                DateTime?
  sifilis1Resultado            String?
  chagasFecha                  DateTime?
  chagasResultado              String?
  ptogResultado                String?
  rubeolaIggResultado          String?
  
  // Ecografías
  eco1Fecha                    DateTime?
  eco1Interpretacion           String?
  eco2Fecha                    DateTime?
  eco2Interpretacion           String?
  eco3Fecha                    DateTime?
  eco3Interpretacion           String?

  // Tratamientos Sifilis
  sifilisDiagnostico           String?
  sifilisSemanasTratamiento    Int?
  sifilisTratamiento           String?
  sifilisCompleto              String?
  sifilisContactos             Int?

  // Vacunas
  toxoideTetanico       String?   // Fecha o dosis aplicada
  tdap                  String?
  influenza             String?
  covid1Fecha           DateTime?
  covid2Fecha           DateTime?

  // Resultado final del embarazo
  fechaParto            DateTime?
  tipoParto             String?   // EUTOCICO, CESAREA, INSTRUMENTADO, ABORTO
  estadoRecienNacido    String?   // VIVO, MUERTO
  pesoRN                Float?    // gramos
  tallaRN               Float?    // centímetros
  apgar                 String?   // ej: "8/9"
  
  // Postparto y Recién Nacido FOMAG
  presentoMme             String?
  dxMme                   String?
  zikaGestacion           String?
  institucionParto        String?
  eventoObstetrico        String?
  partoHumanizado         String?
  lactanciaExclusiva      String?
  tshRnFecha              DateTime?
  tshRnResultado          String?
  tamizajeAuditivoRn      String?
  altaRnFecha             DateTime?
  consultaRnFecha         DateTime?
  altaPuerperaFecha       DateTime?
  consultaPuerperaFecha   DateTime?
  metodoPostparto         String?
  metodoElegido           String?
  entregaMedicamentos     String?
  motivoCierre            String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}
