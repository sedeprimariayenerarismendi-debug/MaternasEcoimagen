{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": {
        "rootDirectory": "backend",
        "builder": "DOCKER"
      },
      "config": {
        "numReplicas": 1,
        "healthcheckPath": "/api/health"
      }
    },
    "frontend": {
      "source": {
        "rootDirectory": "frontend",
        "builder": "DOCKER"
      },
      "config": {
        "numReplicas": 1
      }
    }
  }
}
  
